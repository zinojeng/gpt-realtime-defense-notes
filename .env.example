# 必填：OpenAI API key（後端使用，不會暴露在前端）
OPENAI_API_KEY=

# 可選：Realtime 轉錄模型，預設為 gpt-4o-transcribe
# 若 OpenAI 已釋出 gpt-realtime-whisper，可改用：
# OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# 可選：階段摘要與最終紀錄的 LLM，預設 gpt-4o-mini
# 若要追求品質，可改 gpt-4o 或更高階模型
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# 可選：階段摘要間隔（毫秒），預設 300000（5 分鐘）
# 由前端透過 /api/config 在執行時讀取，因此 Zeabur 改完只需重啟 service，
# 不需重新 build。
SUMMARY_INTERVAL_MS=300000

# 強烈建議（公開部署必填）：共用密碼。
# 設定後，所有 API（/api/realtime/token、/api/summarize/*、/api/review-terms）
# 都必須在請求標頭帶 `x-app-secret: <此值>`，前端會自動從本機 localStorage 帶。
# 沒設定時 API 為公開狀態，僅適合本機或內網。
APP_SHARED_SECRET=
